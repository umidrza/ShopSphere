<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<config>
		<add key="signatureValidationMode" value="accept" />
	</config>

	<packageSources>
		<clear />
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
	</packageSources>

	<config>
		<add key="globalPackagesFolder" value="/root/.nuget/packages" />
	</config>
</configuration>