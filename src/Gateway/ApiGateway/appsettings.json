{
  "ReverseProxy": {
    "Routes": {
      "authRoute": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },

      "productRoute": {
        "ClusterId": "productCluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },

      "cartRoute": {
        "ClusterId": "cartCluster",
        "Match": {
          "Path": "/api/cart/{**catch-all}"
        }
      },

      "orderRoute": {
        "ClusterId": "orderCluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "authCluster": {
        "Destinations": {
          "auth": {
            "Address": "https://localhost:7146/"
          }
        }
      },

      "productCluster": {
        "Destinations": {
          "product": {
            "Address": "https://localhost:7036"
          }
        }
      },

      "cartCluster": {
        "Destinations": {
          "cart": {
            "Address": "https://localhost:7029/"
          }
        }
      },

      "orderCluster": {
        "Destinations": {
          "order": {
            "Address": "https://localhost:7207"
          }
        }
      }
    }
  }
}